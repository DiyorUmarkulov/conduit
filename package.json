{
  "name": "conduit-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo for Conduit (@theconduit/*): a TypeScript command/event operation bus with pluggable transports (in-memory, SQL outbox, Kafka, RabbitMQ, NATS), schema tooling, and framework integrations.",
  "keywords": [
    "conduit",
    "theconduit",
    "command-bus",
    "event-bus",
    "outbox",
    "kafka",
    "typescript",
    "monorepo"
  ],
  "homepage": "https://github.com/DiyorUmarkulov/conduit#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/DiyorUmarkulov/conduit.git"
  },
  "bugs": {
    "url": "https://github.com/DiyorUmarkulov/conduit/issues"
  },
  "license": "MIT",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:all": "./scripts/build-all.sh",
    "test": "pnpm -r test",
    "test:all": "./scripts/test-all.sh",
    "e2e": "vitest run --config e2e/vitest.config.ts",
    "e2e:brokers": "CONDUIT_E2E_BROKERS=1 vitest run --config e2e/vitest.config.ts",
    "typecheck": "pnpm -r typecheck",
    "benchmark": "node ./scripts/run-benchmarks.mjs",
    "benchmark:check": "node ./scripts/check-benchmarks.mjs",
    "clean": "pnpm -r clean",
    "docs:api": "./scripts/generate-api-docs.sh",
    "deps:circular": "./scripts/check-circular-deps.sh",
    "publish:dry-run": "./scripts/publish-dry-run.sh"
  },
  "devDependencies": {
    "amqplib": "^0.10.5",
    "@types/node": "^22.13.10",
    "kafkajs": "^2.2.4",
    "nats": "^2.29.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
