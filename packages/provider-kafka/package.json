{
  "name": "@theconduit/provider-kafka",
  "version": "0.1.1",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Apache Kafka transport for Conduit: produce and consume command/event envelopes via KafkaJS, with partitioning helpers and Avro serialization wired to @theconduit/schema-registry.",
  "keywords": [
    "conduit",
    "theconduit",
    "kafka",
    "kafkajs",
    "event-streaming",
    "message-bus",
    "avro",
    "typescript"
  ],
  "homepage": "https://github.com/DiyorUmarkulov/conduit/tree/main/packages/provider-kafka",
  "repository": {
    "type": "git",
    "url": "https://github.com/DiyorUmarkulov/conduit.git",
    "directory": "packages/provider-kafka"
  },
  "bugs": {
    "url": "https://github.com/DiyorUmarkulov/conduit/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@conduit/core": "workspace:@theconduit/core@*",
    "@conduit/schema-registry": "workspace:@theconduit/schema-registry@*",
    "avsc": "^5.7.7"
  }
}
