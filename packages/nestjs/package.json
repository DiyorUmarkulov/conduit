{
  "name": "@theconduit/nestjs",
  "version": "0.1.1",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "NestJS integration for Conduit: register the operation bus in the DI container, inject ConduitBus, and declare command/event handlers with decorators aligned to Nest lifecycle.",
  "keywords": [
    "conduit",
    "theconduit",
    "nestjs",
    "nestjs-module",
    "command-bus",
    "event-bus",
    "typescript"
  ],
  "homepage": "https://github.com/DiyorUmarkulov/conduit/tree/main/packages/nestjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/DiyorUmarkulov/conduit.git",
    "directory": "packages/nestjs"
  },
  "bugs": {
    "url": "https://github.com/DiyorUmarkulov/conduit/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@conduit/core": "workspace:@theconduit/core@*"
  }
}
