{
  "name": "@theconduit/testing",
  "version": "0.1.1",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Test kit for Conduit: fake transport providers, DLQ doubles, envelope/command/event builders, and wiring helpers so you can exercise handlers and routers without real brokers or databases.",
  "keywords": [
    "conduit",
    "theconduit",
    "testing",
    "test-utils",
    "mock",
    "vitest",
    "typescript"
  ],
  "homepage": "https://github.com/DiyorUmarkulov/conduit/tree/main/packages/testing",
  "repository": {
    "type": "git",
    "url": "https://github.com/DiyorUmarkulov/conduit.git",
    "directory": "packages/testing"
  },
  "bugs": {
    "url": "https://github.com/DiyorUmarkulov/conduit/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@conduit/core": "workspace:@theconduit/core@*"
  }
}
