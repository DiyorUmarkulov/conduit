{
  "name": "@theconduit/provider-rabbitmq",
  "version": "0.1.1",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "RabbitMQ (AMQP) transport for Conduit using amqplib: publish and consume operation envelopes with channel pooling and resilience helpers for production queues and exchanges.",
  "keywords": [
    "conduit",
    "theconduit",
    "rabbitmq",
    "amqp",
    "amqplib",
    "message-queue",
    "typescript"
  ],
  "homepage": "https://github.com/DiyorUmarkulov/conduit/tree/main/packages/provider-rabbitmq",
  "repository": {
    "type": "git",
    "url": "https://github.com/DiyorUmarkulov/conduit.git",
    "directory": "packages/provider-rabbitmq"
  },
  "bugs": {
    "url": "https://github.com/DiyorUmarkulov/conduit/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@conduit/core": "workspace:@theconduit/core@*"
  }
}
