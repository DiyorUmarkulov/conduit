{
  "name": "@theconduit/cli",
  "version": "0.1.1",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Official conduit CLI: list routes, run outbox migrations, inspect and replay DLQ entries, validate and diff payload schemas — operational tooling for Conduit deployments.",
  "keywords": [
    "conduit",
    "theconduit",
    "cli",
    "dlq",
    "outbox",
    "schema",
    "devops",
    "typescript"
  ],
  "homepage": "https://github.com/DiyorUmarkulov/conduit/tree/main/packages/cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/DiyorUmarkulov/conduit.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/DiyorUmarkulov/conduit/issues"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "conduit": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@conduit/core": "workspace:@theconduit/core@*",
    "@conduit/provider-outbox": "workspace:@theconduit/provider-outbox@*"
  }
}
