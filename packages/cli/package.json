{
  "name": "@conduit/cli",
  "version": "0.1.0",
  "description": "CLI utilities for Conduit operations, routes, and DLQ",
  "license": "MIT",
  "type": "module",
  "bin": {
    "conduit": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@conduit/core": "workspace:*",
    "@conduit/provider-outbox": "workspace:*"
  }
}
